# Copy to .env and fill in. The .env file is gitignored.

# MiniMax M2.7 via OpenRouter (OpenAI-compatible API).
# Get a key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# HuggingFace — scripts resolve your namespace at runtime via `whoami()`.
# Set HF_USERNAME only to override (e.g. push under an org instead of your user).
HF_USERNAME=

# HuggingFace token — only needed if `huggingface-cli login` wasn't run.
# `huggingface-cli whoami` should work without this if you're already logged in.
HF_TOKEN=
